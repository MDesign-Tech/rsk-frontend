# Absolute URL of the Express backend API, used SERVER-SIDE by the BFF route
# handlers in src/app/api/* to forward requests. Must be a full URL.
# Local dev:
NEXT_PUBLIC_SERVER_API_URL=http://localhost:5000/api
# Production (Vercel):
# NEXT_PUBLIC_SERVER_API_URL=https://rsk-backend-api.vercel.app/api

# Cloudinary configuration for client-side image uploads
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
NEXT_PUBLIC_CLOUDINARY_API_KEY=your_api_key
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your_upload_preset
